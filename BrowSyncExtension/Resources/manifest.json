{
  "manifest_version": 3,
  "name": "BrowSync",
  "version": "1.0.0",
  "description": "Multi-browser sync powered by BrowSync",
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "bookmarks",
    "tabs",
    "cookies",
    "storage",
    "scripting",
    "notifications",
    "alarms",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BrowSync"
  },
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "16.0"
    }
  }
}